@model IEnumerable<ExpenseManager.Models.Expense>
@{
    ViewData["Title"] = "Pending Expenses";
}

<h1>Pending Expenses</h1>

<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Submitted By</th>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Amount</th>
                            <th>Date</th>
                            <th>Submitted</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.User.FullName</td>
                                <td>@item.Title</td>
                                <td>@item.Category.Name</td>
                                <td>@item.Amount.ToString("C")</td>
                                <td>@item.Date.ToShortDateString()</td>
                                <td>@item.CreatedAt.ToShortDateString()</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                                    <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-sm btn-success">Approve</a>
                                    <a asp-action="Reject" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Reject</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <p class="mb-0">There are no pending expenses that require your approval.</p>
            </div>
        }
    </div>
</div>