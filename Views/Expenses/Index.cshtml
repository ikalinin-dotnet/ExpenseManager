<!-- Views/Expenses/Index.cshtml -->
@model IEnumerable<ExpenseManager.Models.Expense>
@{
    ViewData["Title"] = "My Expenses";
}

<h1>My Expenses</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.Category.Name</td>
                            <td>@item.Amount.ToString("C")</td>
                            <td>@item.Date.ToShortDateString()</td>
                            <td>
                                @switch (item.Status)
                                {
                                    case ExpenseStatus.Pending:
                                        <span class="badge bg-warning">Pending</span>
                                        break;
                                    case ExpenseStatus.Approved:
                                        <span class="badge bg-success">Approved</span>
                                        break;
                                    case ExpenseStatus.Rejected:
                                        <span class="badge bg-danger">Rejected</span>
                                        break;
                                }
                            </td>
                            <td>@item.CreatedAt.ToShortDateString()</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                                @if (item.Status == ExpenseStatus.Pending)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <p class="text-muted">No expenses found. <a asp-action="Create">Create your first expense</a>.</p>
        }
    </div>
</div>